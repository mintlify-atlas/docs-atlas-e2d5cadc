  "keyFeatures": [
    "Firebase authentication with email/password",
    "Product catalog with search and filtering",
    "Shopping cart with checkout flow",
    "LARP event management and registration",
    "User reviews and ratings",
    "Admin panel for managing products, events, and users",
    "Image upload via Firebase Storage",
    "Local notifications for event reminders",
    "Multi-platform support (iOS, Android, Web, Desktop)"
  ],
  "publicApiSurface": [
    "FirebaseBackend.auth - Firebase authentication",
    "FirebaseBackend.firestore - Cloud Firestore instance",
    "FirebaseBackend.storage - Firebase Storage instance",
    "FirebaseBackend.users - Users collection reference",
    "FirebaseBackend.products - Products collection reference",
    "FirebaseBackend.events - Events collection reference",
    "FirebaseBackend.reviews - Reviews collection reference",
    "CartProvider - Shopping cart state management",
    "AuthSession - User session management",
    "ProductService - Product CRUD operations",
    "RoleplayEventService - Event CRUD operations",
    "OrderService - Order management",
    "UserReviewService - Review management"
  ]
